---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/Eyebrow.astro";

const team = [
  {
    initials: "RW",
    name: "Robbie",
    role: "Framework architecture",
    areas: ["Strategy interface", "Pipeline orchestration", "Data layer", "Scorecard generator", "Reporting"],
    blurb: "Owns the spine of the project: the strategy base class every member subclasses, the data-layer abstraction across ten providers, the metrics engine, and the four-page scorecard that drops out the other end.",
  },
  {
    initials: "S",
    name: "Sachit",
    role: "Event engine + synthetic data",
    areas: ["Event-driven backtester", "cGAN training", "Heston stochastic vol", "Regime conditioning"],
    blurb: "Owns the event-driven engine (stop / limit / OCO fills intrabar), the conditional Wasserstein GAN trained on four real SPY regimes, and the Heston Monte Carlo path — the two synthetic-data lanes that stress-test every strategy.",
  },
  {
    initials: "C",
    name: "Connor",
    role: "Monte Carlo simulation",
    areas: ["GBM baseline", "Block bootstrap", "Noise injection", "Distributional statistics"],
    blurb: "Owns the Monte Carlo layer: the GBM sanity baseline (positive Sharpe here = overfitting), the block-bootstrap resampler, the configurable noise-injection generator, and the distribution plots that sit on page three of the scorecard.",
  },
];
---
<Base title="Team">
  <section class="max-w-wide mx-auto px-6 md:px-10 pt-14 md:pt-20 pb-10 border-b border-hair">
    <Eyebrow label="Contributors" index="Ch. VII" />
    <h1 class="font-display font-medium text-ink leading-[1.02] text-[2.6rem] md:text-[3.8rem] mt-4">
      Three people,
      <em class="italic text-primary">four pillars.</em>
    </h1>
    <p class="mt-5 max-w-prose text-[1.05rem] leading-[1.65] text-ink">
      The framework is a MAIF project. Work is split so each pillar has an owner and the others
      can review without duplication. Role split reproduced from <code class="font-mono text-[0.88em] bg-[#F2EEE6] border border-hair px-1">README.md</code>
      and <code class="font-mono text-[0.88em] bg-[#F2EEE6] border border-hair px-1">roles.md</code>.
    </p>
  </section>

  <section class="max-w-wide mx-auto px-6 md:px-10 py-14">
    <ul class="grid md:grid-cols-3 gap-6">
      {team.map((m) => (
        <li class="border border-hair bg-white">
          <div class="aspect-[5/4] bg-paper border-b border-hair grid place-items-center relative overflow-hidden">
            <div class="font-display text-[7rem] md:text-[9rem] leading-none text-primary">
              {m.initials}
            </div>
            <div class="absolute top-4 left-4 right-4 flex items-center justify-between">
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">MAIF</span>
              <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">contributor</span>
            </div>
          </div>
          <div class="p-5">
            <h2 class="font-display text-[1.8rem] leading-none text-ink">{m.name}</h2>
            <div class="mt-1 font-mono text-[0.78rem] uppercase tracking-[0.12em] text-primary">{m.role}</div>
            <p class="mt-4 text-[0.98rem] leading-[1.65] text-ink">{m.blurb}</p>
            <ul class="mt-4 pt-3 border-t border-hair flex flex-wrap gap-1.5">
              {m.areas.map((a) => (
                <li class="font-mono text-[0.7rem] uppercase tracking-[0.08em] text-ink border border-hair px-2 py-1">
                  {a}
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <hr class="hairline" />

  <section class="max-w-wide mx-auto px-6 md:px-10 py-14">
    <div class="max-w-prose">
      <Eyebrow label="The club" />
      <h2 class="font-display text-[2rem] mt-3 leading-[1.15]">
        Minutemen Alternative Investment Fund.
      </h2>
      <p class="mt-4 text-[1rem] leading-[1.7] text-ink">
        MAIF is UMass Amherst's student-run investment fund. The framework is a shared,
        semester-persistent piece of infrastructure: any member can plug their strategy in, get a
        standardized scorecard back, and hand the code off to the next cohort without losing the
        institutional knowledge. If you're a MAIF member and want to add a strategy, start from
        the <a href="/get-started" class="primary">Get started</a> page.
      </p>
    </div>
  </section>
</Base>
